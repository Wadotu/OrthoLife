<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:orientation="vertical">

    <!-- Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:background="@color/burgundy">

        <Button
            android:id="@+id/btn_prev_day"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textColor="@color/komboskini_white"
            android:text="&lt;"
            style="@style/OrthodoxTextButton" />

        <LinearLayout
            android:id="@+id/date_picker_trigger"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tv_det_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/gold"
                android:textStyle="bold"
                android:padding="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="18sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_next_day"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:textColor="@color/komboskini_white"
            android:text="&gt;"
            style="@style/OrthodoxTextButton" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/iv_det_icon"
                android:layout_width="200dp"
                android:layout_height="250dp"
                android:scaleType="fitCenter"
                android:layout_marginBottom="16dp"
                android:src="@drawable/rounded_card_bg"
                android:contentDescription="@string/icons"/>

            <TextView
                android:id="@+id/tv_det_feast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textColor="@color/ivory"
                android:textAlignment="center"
                android:layout_marginBottom="8dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_det_tone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/ivory"
                android:layout_marginBottom="8dp"
                tools:text="Tone 1"/>

            <TextView
                android:id="@+id/tv_det_fasting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/accent_rose"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/commemorations"
                android:textSize="20sp"
                android:textColor="@color/gold"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:paddingBottom="4dp"/>

            <TextView
                android:id="@+id/tv_det_commemorations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/ivory"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/readings"
                android:textSize="20sp"
                android:textColor="@color/gold"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_det_readings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/ivory"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lives_of_saints"
                android:textSize="20sp"
                android:textColor="@color/gold"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_det_stories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/ivory"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
