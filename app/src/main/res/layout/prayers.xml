<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor"
    android:padding="16dp">

    <TextView
        android:id="@+id/prayer_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/prayers"
        android:textColor="@color/gold"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="70dp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/prayer_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

    <ScrollView
        android:id="@+id/prayer_content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/prayer_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ivory"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/prayer_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ivory"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_back_to_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back_to_list"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        style="@style/OrthodoxButton"/>

</LinearLayout>
