<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/widget_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/rounded_card_bg"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp">

        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_round"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/widget_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gold"
                android:textAlignment="center"
                android:fontFamily="@font/mbb"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/widget_feast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ivory"
                android:textSize="20sp"
                android:textAlignment="center"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_tone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ivory"
                android:textAlignment="center"
                android:textSize="17sp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/widget_reading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gold"
                android:textAlignment="center"
                android:textSize="13sp"
                android:textStyle="italic"
                android:maxLines="4"
                android:ellipsize="end"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/widget_fasting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/accent_rose"
                android:textSize="17sp"/>
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_widget_refresh"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_rotate"
        android:scaleType="centerInside"
        android:contentDescription="Refresh"
        android:padding="6dp"/>

</FrameLayout>
