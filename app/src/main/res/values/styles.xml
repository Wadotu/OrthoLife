<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--  Gold + Burgundy Modern Rounded Button  -->
    <style name="OrthodoxButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/gold</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textColor">@color/charcoal</item>
        <item name="android:fontFamily">@font/mbr</item>
        <item name="android:textSize">40sp</item>

        <!-- 눌림/포커스 효과를 버건디로 -->
        <item name="rippleColor">@color/goldforclick</item>
    </style>


    <!-- Text Button (글씨만 있는 타입, 아이보리/금 조합) -->
    <style name="OrthodoxTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/gold</item>
        <item name="rippleColor">@color/accent_rose</item>
    </style>


    <!-- Card Style (성화 느낌: 어두운 배경 + 금색 보더) -->
    <style name="OrthodoxCard" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/ivory</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/gold</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:clipToOutline">true</item>
        <item name="android:shape">@style/OrthodoxCardShape</item>
    </style>

    <style name="OrthodoxCardShape">
        <item name="cornerSize">16dp</item>
    </style>

</resources>